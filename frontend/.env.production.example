# Production API endpoint
NEXT_PUBLIC_API_URL=https://YOUR_RENDER_API_URL

# Wallet provider
NEXT_PUBLIC_WALLET_PROVIDER_URL=https://YOUR_WALLET_PROVIDER_URL

# Smart contract
NEXT_PUBLIC_CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS

# Admin wallet
