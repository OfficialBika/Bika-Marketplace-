APP_NAME=Bika Marketplace
ENV=production

# Database
MONGO_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/bika_marketplace
MONGO_DB=bika_marketplace

# Security
JWT_SECRET=change_me
SECURITY_SECRET=change_secret

# Render CORS
CORS_ORIGINS=https://YOUR_FRONTEND.onrender.com,http://localhost:3000
CORS_ENABLED=true

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL
SMTP_PASSWORD=YOUR_APP_PASSWORD

# Blockchain
CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS
ADMIN_WALLET_ADDRESS=YOUR_ADMIN_WALLET_ADDRESS

# Marketplace
COIN_NAME=BKC
SHOW_RARITY=Supreme
FEATURED_LIMIT=8
CHARACTER_ROTATION=5000
FEATURED_SORT=random

AUCTION_ENABLED=true
TRADE_ENABLED=true
SPIN_ENABLED=true
WALLET_ENABLED=true
PURCHASE_ENABLED=true
MARKETPLACE_ENABLED=true
ORDER_SYSTEM_ENABLED=true
OWNERSHIP_ENABLED=true
HEALTH_CHECK_ENABLED=true
PRODUCTION_READY=true
